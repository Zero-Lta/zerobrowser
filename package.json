{
  "name": "zero-browser",
  "version": "1.1.0",
  "description": "A modern, lightweight desktop browser built with Electron",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build-win": "electron-builder --win"
  },
  "keywords": [
    "browser",
    "electron",
    "web",
    "chromium"
  ],
  "author": "Zero Browser Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.zerobrowser.app",
    "productName": "ZeroBrowser",
    "executableName": "ZeroBrowser",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zero Browser"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "SEU_USER_GITHUB",
      "repo": "ZeroBrowser"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
